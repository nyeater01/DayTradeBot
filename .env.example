# --- DayTradeBot (intraday) ---
# Second Alpaca paper account + separate Discord webhook from StockBot.
# Linux: ./scripts/run.sh --once
# Manual: python -m daytradebot --once

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_TRADING_MODE=paper
# Live only:
# DAYTRADEBOT_CONFIRM_LIVE=YES_I_ACCEPT_REAL_MONEY_RISK

DAYTRADEBOT_SYMBOLS=SPY,QQQ
DAYTRADEBOT_POLL_SECONDS=30
DAYTRADEBOT_BAR_MINUTES=1
DAYTRADEBOT_SESSION_OPEN=09:30
DAYTRADEBOT_SESSION_CLOSE=16:00

# ICT killzones (ET): asia, london, ny_am, ny_pm
DAYTRADEBOT_KILLZONES=ny_am,ny_pm
DAYTRADEBOT_FLAT_OUTSIDE_KILLZONE=1
DAYTRADEBOT_FLAT_AT_CLOSE=1

DAYTRADEBOT_DEPLOY_FRAC=0.5
DAYTRADEBOT_MAX_TRADES_PER_DAY=3
DAYTRADEBOT_MAX_DAILY_LOSS_PCT=0.03
DAYTRADEBOT_STOP_LOSS_PCT=0.005
DAYTRADEBOT_TAKE_PROFIT_PCT=0.01
DAYTRADEBOT_CONFLUENCE_MIN=3
DAYTRADEBOT_PIVOT_TOLERANCE_PCT=0.0015
DAYTRADEBOT_VP_BINS=50
DAYTRADEBOT_VALUE_AREA_PCT=0.70

DAYTRADEBOT_RISK_STATE_DIR=.state
DAYTRADEBOT_KILL_SWITCH=0
# DAYTRADEBOT_KILL_SWITCH_FILE=/path/to/KILL

# Separate Discord channel from StockBot
# DAYTRADEBOT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DAYTRADEBOT_DISCORD_ON_TRADE=1
# Full cycle embed every poll (default off)
# DAYTRADEBOT_DISCORD_CYCLE_REPORT=0
# Balance + change vs last post (28800 = 8 hours; 0 = off)
DAYTRADEBOT_DISCORD_BALANCE_INTERVAL_SEC=28800
DAYTRADEBOT_DISCORD_SESSION_NOTICES=1
DAYTRADEBOT_DISCORD_HOLIDAY_AHEAD_DAYS=3
DAYTRADEBOT_DISCORD_MIN_INTERVAL_SEC=2

DAYTRADEBOT_ALPACA_RETRY_ATTEMPTS=3
DAYTRADEBOT_ALPACA_RETRY_BASE_DELAY_SEC=2.0
# DAYTRADEBOT_LOG_FILE=logs/daytradebot.log
